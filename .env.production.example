# Backend production example
NODE_ENV=production
PORT=3001

# PostgreSQL on Docker network
DATABASE_URL=postgresql://debt_command_user:REPLACE_WITH_PASSWORD@postgresql:5432/debt_command

# Use a long random value in production
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Netlify frontend origin
FRONTEND_ORIGIN=https://debt.jorgesotocoder.com